# Bot Configuration
BOT_TOKEN=YOUR_BOT_TOKEN

# Google OAuth
GOOGLE_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_CLIENT_SECRET

# REDIRECT_URI — leave blank to auto-detect (recommended)
# Only set this if auto-detection fails or you use a domain/reverse proxy
# REDIRECT_URI=http://YOUR_IP:1025/oauth_callback

# MongoDB
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority

# Port for web server + token receiver
PORT=1025

# OAuth Mode: internal (bot handles OAuth) | external (use separate OAuth service)
OAUTH_MODE=internal

# External OAuth service URL — only needed when OAUTH_MODE=external
OAUTH_SERVICE_URL=https://oauth.arshman.me

# Bot public URL — leave blank to auto-detect via ipify/ifconfig.me
# BOT_SERVER_URL=http://YOUR_IP:1025

# Local Telegram API Server (optional, enables >50MB files)
USE_LOCAL_SERVER=False
LOCAL_SERVER_URL=http://localhost:8081
